{
  "name": "CESP DS",
  "slug": "cesp",
  "version": "0.1.0",
  "description": "A CSS-variable-based component library with 14 React components, 51 design tokens, and a custom icon system. Built with tsup for tree-shakeable npm distribution.",
  "author": {
    "name": "hulusi-tunc",
    "github": "hulusi-tunc",
    "avatar": "https://github.com/hulusi-tunc.png"
  },
