  "components": [
    {
      "name": "Button",
      "variants": 5,
      "sizes": 4,
      "file": "button.tsx",
      "displaySize": "md",
      "examples": [
        { "name": "Primary", "code": "<Button>Save changes</Button>" },
        { "name": "Secondary", "code": "<Button variant=\"secondary\">Cancel</Button>" },
        { "name": "Tertiary", "code": "<Button variant=\"tertiary\">Learn more</Button>" },
        { "name": "Link", "code": "<Button variant=\"link-color\">Read documentation</Button>" },
        { "name": "Destructive", "code": "<Button destructive>Delete account</Button>" },
        { "name": "Loading", "code": "<Button loading>Saving…</Button>" },
        { "name": "Disabled", "code": "<Button disabled>Can't click</Button>" },
        { "name": "Small", "code": "<Button size=\"sm\">Sm button</Button>" },
        { "name": "Extra Large", "code": "<Button size=\"xl\">XL button</Button>" }
      ],
      "props": {
        "variant": {
          "type": "enum",
          "values": ["primary", "secondary", "tertiary", "link-color", "link-gray"],
          "default": "primary"
        },
        "size": {
          "type": "enum",
          "values": ["sm", "md", "lg", "xl"],
          "default": "md"
        },
        "destructive": { "type": "boolean", "default": false },
        "loading": { "type": "boolean", "default": false },
        "disabled": { "type": "boolean", "default": false },
        "children": { "type": "string", "default": "Click me" }
      }
    },
    {
      "name": "Badge",
      "variants": 3,
      "sizes": 3,
      "file": "badge.tsx",
      "displaySize": "sm",
      "examples": [
        { "name": "Default", "code": "<Badge>New</Badge>" },
        { "name": "Brand pill", "code": "<Badge color=\"brand\" type=\"pill-color\">Premium</Badge>" },
        { "name": "Success modern", "code": "<Badge color=\"success\" type=\"badge-modern\">Active</Badge>" },
        { "name": "Error", "code": "<Badge color=\"error\">Failed</Badge>" },
        { "name": "Warning", "code": "<Badge color=\"warning\">Pending</Badge>" },
        { "name": "With dot", "code": "<Badge color=\"success\" icon=\"dot\">Online</Badge>" },
        { "name": "Small", "code": "<Badge size=\"sm\">SM</Badge>" },
        { "name": "Large", "code": "<Badge size=\"lg\">Large</Badge>" }
      ],
      "props": {
        "color": {
          "type": "enum",
          "values": ["gray", "brand", "error", "warning", "success", "gray-blue", "blue-light", "blue", "indigo", "purple", "pink", "orange"],
          "default": "gray"
        },
        "type": {
          "type": "enum",
          "values": ["pill-color", "badge-color", "badge-modern"],
          "default": "badge-color"
        },
        "size": { "type": "enum", "values": ["sm", "md", "lg"], "default": "md" },
        "icon": {
          "type": "enum",
          "values": ["none", "dot", "icon-leading", "icon-trailing", "x-close", "avatar", "icon-only"],
          "default": "none"
        },
        "children": { "type": "string", "default": "Badge" }
      }
    },
    {
      "name": "Badge Group",
      "variants": 1,
      "sizes": 1,
      "file": "badge-group.tsx",
      "displaySize": "md",
      "examples": [
        { "name": "Leading label", "code": "<BadgeGroup badgeLabel=\"New\" color=\"brand\">Just shipped</BadgeGroup>" },
        { "name": "Trailing", "code": "<BadgeGroup badgeLabel=\"v2.0\" badgePosition=\"trailing\" color=\"success\">Upgrade</BadgeGroup>" },
        { "name": "Large", "code": "<BadgeGroup badgeLabel=\"Beta\" size=\"lg\" color=\"warning\">Try it out</BadgeGroup>" }
      ],
      "props": {
        "color": {
          "type": "enum",
          "values": ["gray", "brand", "error", "warning", "success", "gray-blue", "blue-light", "blue", "indigo", "purple", "pink", "orange"],
          "default": "gray"
        },
        "type": { "type": "enum", "values": ["pill-color", "badge-modern"], "default": "pill-color" },
        "size": { "type": "enum", "values": ["md", "lg"], "default": "md" },
        "badgePosition": { "type": "enum", "values": ["leading", "trailing"], "default": "leading" },
        "badgeLabel": { "type": "string", "default": "New" },
        "children": { "type": "string", "default": "Latest update" }
      }
    },
    {
      "name": "Input",
      "variants": 1,
      "sizes": 2,
      "file": "input.tsx",
      "displaySize": "md",
      "examples": [
        { "name": "Email", "code": "<Input label=\"Email\" placeholder=\"you@hubera.dev\" />" },
        { "name": "With hint", "code": "<Input label=\"Team name\" hint=\"Visible to all members\" placeholder=\"Acme\" />" },
        { "name": "With error", "code": "<Input label=\"Username\" error=\"Already taken\" />" },
        { "name": "With leading text", "code": "<Input label=\"Website\" leadingText=\"https://\" trailingText=\".com\" placeholder=\"hubera\" />" },
        { "name": "Small size", "code": "<Input inputSize=\"sm\" placeholder=\"Search…\" />" }
      ],
      "props": {
        "inputSize": { "type": "enum", "values": ["sm", "md"], "default": "md" },
        "label": { "type": "string", "default": "Label" },
        "placeholder": { "type": "string", "default": "Type here…" },
        "hint": { "type": "string", "default": "" },
        "error": { "type": "string", "default": "" },
        "leadingText": { "type": "string", "default": "" },
        "trailingText": { "type": "string", "default": "" },
        "disabled": { "type": "boolean", "default": false }
      }
    },
    {
      "name": "Textarea",
      "variants": 1,
      "sizes": 2,
      "file": "textarea.tsx",
      "displaySize": "md",
      "examples": [
        { "name": "Default", "code": "<Textarea label=\"Message\" placeholder=\"Your thoughts…\" />" },
        { "name": "With hint", "code": "<Textarea label=\"Bio\" hint=\"A sentence or two about you\" />" },
        { "name": "With error", "code": "<Textarea label=\"Notes\" error=\"Must be under 280 chars\" />" }
      ],
      "props": {
        "textareaSize": { "type": "enum", "values": ["sm", "md"], "default": "md" },
        "label": { "type": "string", "default": "Message" },
        "placeholder": { "type": "string", "default": "Your thoughts…" },
        "hint": { "type": "string", "default": "" },
        "error": { "type": "string", "default": "" },
        "disabled": { "type": "boolean", "default": false }
      }
    },
    {
      "name": "Tag",
      "variants": 1,
      "sizes": 3,
      "file": "tag.tsx",
      "displaySize": "sm",
      "examples": [
        { "name": "Default", "code": "<Tag>design</Tag>" },
        { "name": "With dot", "code": "<Tag dot dotColor=\"#17B26A\">Active</Tag>" },
        { "name": "Checkbox", "code": "<Tag checkbox checked>Selected</Tag>" },
        { "name": "With count", "code": "<Tag count={42}>Issues</Tag>" },
        { "name": "Large", "code": "<Tag size=\"lg\">tokens</Tag>" },
        { "name": "Disabled", "code": "<Tag disabled>read-only</Tag>" }
      ],
      "props": {
        "size": { "type": "enum", "values": ["sm", "md", "lg"], "default": "md" },
        "dot": { "type": "boolean", "default": false },
        "dotColor": { "type": "string", "default": "#17B26A" },
        "count": { "type": "number", "default": 0 },
        "checkbox": { "type": "boolean", "default": false },
        "checked": { "type": "boolean", "default": false },
        "disabled": { "type": "boolean", "default": false },
        "children": { "type": "string", "default": "tag" }
      }
    },
    {
      "name": "Tabs",
      "variants": 2,
      "sizes": 2,
      "file": "tabs.tsx",
      "displaySize": "lg",
      "examples": [
        {
          "name": "Underline",
          "code": "<Tabs variant=\"underline\" items={[{label:\"Overview\",value:\"ov\"},{label:\"Tokens\",value:\"tk\"},{label:\"Components\",value:\"cp\"}]} defaultValue=\"ov\" />"
        },
        {
          "name": "Filled",
          "code": "<Tabs variant=\"filled\" items={[{label:\"Day\",value:\"d\"},{label:\"Week\",value:\"w\"},{label:\"Month\",value:\"m\"}]} defaultValue=\"d\" />"
        },
        {
          "name": "Full width",
          "code": "<Tabs fullWidth items={[{label:\"Home\",value:\"h\"},{label:\"Settings\",value:\"s\"}]} defaultValue=\"h\" />"
        }
      ],
      "props": {
        "variant": { "type": "enum", "values": ["underline", "filled"], "default": "underline" },
        "size": { "type": "enum", "values": ["sm", "md"], "default": "sm" },
        "orientation": { "type": "enum", "values": ["horizontal", "vertical"], "default": "horizontal" },
        "fullWidth": { "type": "boolean", "default": false }
      }
    },
    {
